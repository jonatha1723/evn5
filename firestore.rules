rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // =====================================================
    // 1. AJUDANTES GLOBAIS (SINTAXE CEL CORRETA)
    // =====================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Admin principal do sistema - Controle Total e Permanente
    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email == "jogonesteterp@gmail.com";
    }

    // Verifica se o usuário não está banido. Admin sempre passa.
    function isNotBanned() {
      return isAdmin() || (
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) || (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBanned', false) == false ||
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('bannedUntil', 0) != 0 && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('bannedUntil', 0) < request.time.toMillis())
        )
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validação de estrutura básica de usuário
    function isValidUserSchema(data) {
      return data.uid is string && 
             data.uid == request.auth.uid &&
             data.displayName is string && 
             data.displayName.size() <= 60 &&
             data.uniqueCode is string &&
             data.uniqueCode.size() <= 15;
    }

    // Lógica para permitir que outros usuários adicionem o usuário aos contatos
    function canUpdateMutualContacts(userId) {
      return isSignedIn() && 
             request.auth.uid != userId && 
             isNotBanned() && 
             incoming().diff(existing()).affectedKeys().hasOnly(['contacts']);
    }

    // =====================================================
    // ACESSO ABSOLUTO DO ADMIN (MASTER OVERRIDE)
    // =====================================================
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // -----------------------------------------------------
    // USERS
    // -----------------------------------------------------
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUserSchema(incoming());
      
      allow update: if (
        isOwner(userId) && isNotBanned() && (
          incoming().uid == existing().uid && 
          incoming().uniqueCode == existing().uniqueCode &&
          incoming().get('isBanned', false) == existing().get('isBanned', false) &&
          incoming().get('bannedUntil', 0) == existing().get('bannedUntil', 0) &&
          incoming().diff(existing()).affectedKeys().hasAny(['displayName', 'lastActive', 'settings', 'contacts', 'avatarUrl', 'about'])
        )
      ) || canUpdateMutualContacts(userId);
      
      allow delete: if isOwner(userId) && isNotBanned();
    }

    match /privateKeys/{userId} {
      allow read, write: if isOwner(userId) && isNotBanned();
    }

    // -----------------------------------------------------
    // CHATS & MESSAGES
    // -----------------------------------------------------
    match /chats/{chatId} {
      function isChatMember() {
        return chatId.matches('^' + request.auth.uid + '_.*') ||
               chatId.matches('.*_' + request.auth.uid + '$');
      }
      
      allow read, write: if isSignedIn() && isChatMember();
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && isChatMember();
        allow create: if isSignedIn() && isChatMember() && 
                      isNotBanned() &&
                      incoming().senderId == request.auth.uid &&
                      isValidId(messageId);
        allow delete: if isSignedIn() && isChatMember() && 
                      existing().senderId == request.auth.uid;
      }
    }

    match /typing/{chatId} {
      allow read, write: if isSignedIn() && isNotBanned() && (
        chatId.matches('^' + request.auth.uid + '_.*') ||
        chatId.matches('.*_' + request.auth.uid + '$')
      );
    }

    // -----------------------------------------------------
    // GROUPS
    // -----------------------------------------------------
    match /groups/{groupId} {
      function isGMember() {
        return (request.auth.uid == resource.data.get('adminUid', '')) || 
               (request.auth.uid in resource.data.get('members', [])) || 
               (request.auth.uid in resource.data.get('memberJoinedAt', {}).keys());
      }

      allow read: if isSignedIn() && (isGMember() || isAdmin());
      allow create: if isSignedIn() && isNotBanned() && incoming().adminUid == request.auth.uid;
      
      allow update: if isSignedIn() && isNotBanned() && (
        (existing().get('adminUid', '') == request.auth.uid && incoming().get('isBanned', false) == existing().get('isBanned', false)) ||
        incoming().diff(existing()).affectedKeys().hasAny(['members', 'memberJoinedAt', 'lastMessage', 'lastMessageTime', 'name', 'description', 'avatarUrl', 'customImageUrl'])
      );
      
      allow delete: if isSignedIn() && existing().adminUid == request.auth.uid;

      match /messages/{msgId} {
        function gData() { return get(/databases/$(database)/documents/groups/$(groupId)).data; }
        function isM() {
             return (request.auth.uid in gData().get('members', [])) || 
                    (request.auth.uid in gData().get('memberJoinedAt', {}).keys()) || 
                    gData().get('adminUid', '') == request.auth.uid;
        }

        allow read, list: if isSignedIn() && isM();
        
        allow create: if isSignedIn() && isM() && 
                      (gData().get('isBanned', false) == false || (gData().get('bannedUntil', 0) != 0 && gData().get('bannedUntil', 0) < request.time.toMillis())) && 
                      isNotBanned() && 
                      incoming().senderId == request.auth.uid && 
                      isValidId(msgId);
                      
        allow delete: if isSignedIn() && (
          existing().senderId == request.auth.uid || 
          gData().get('adminUid', '') == request.auth.uid
        );
      }
    }

    // -----------------------------------------------------
    // REQUESTS
    // -----------------------------------------------------
    match /requests/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotBanned() && incoming().fromUid == request.auth.uid;
      allow update: if isSignedIn() && isNotBanned() && (
        existing().toUid == request.auth.uid || existing().fromUid == request.auth.uid
      ) && (
        incoming().diff(existing()).affectedKeys().hasAny(['status', 'updatedAt'])
      );
      allow delete: if isSignedIn() && (
        existing().fromUid == request.auth.uid || 
        existing().toUid == request.auth.uid
      );
    }

    match /requestCounters/{userId} {
      allow read, write: if isOwner(userId) && isNotBanned();
    }

    match /inviteTokens/{tokenId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotBanned() && incoming().creatorUid == request.auth.uid;
      allow update, delete: if isSignedIn() && existing().creatorUid == request.auth.uid;
    }

    match /groupInviteTokens/{tokenId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotBanned(); 
      allow update, delete: if isSignedIn() && existing().creatorUid == request.auth.uid;
    }

    // -----------------------------------------------------
    // BACKUP E HISTÓRICO
    // -----------------------------------------------------
    match /history/{msgId} {
      allow create: if isSignedIn() && isNotBanned();
      allow read, list: if isSignedIn();
    }

    match /userBackups/{uniqueCode} {
      allow write: if isSignedIn() && isNotBanned();
      allow read: if false; 
    }

    match /privateKeyBackups/{uniqueCode} {
      allow write: if isSignedIn() && isNotBanned();
      allow read: if false; 
    }

    // -----------------------------------------------------
    // SEGURANÇA E MONITORAMENTO
    // -----------------------------------------------------
    match /rateLimits/{userId} {
      allow get, write: if isOwner(userId);
    }

    match /abuseReports/{docId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    match /deviceAuth/{fingerprint} {
      allow read: if isSignedIn() && (resource == null || existing().uid == request.auth.uid);
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      allow update, delete: if isSignedIn() && existing().uid == request.auth.uid;
    }
  }
}
